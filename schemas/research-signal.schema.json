{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexwang91/audience-activation-spec/schemas/research-signal.schema.json",
  "title": "Research Signal",
  "description": "Minimal schema for evidence-aware research signals used by Audience Activation Spec.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "signal_id",
    "source_type",
    "audience_description",
    "finding",
    "evidence_label",
    "calibration_level",
    "limitations",
    "recommended_use"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "synthetic_panel",
        "llm_interview",
        "survey",
        "experiment",
        "sales_or_click_behavior",
        "expert_or_team_assumption"
      ]
    },
    "audience_description": {
      "type": "string",
      "minLength": 1
    },
    "finding": {
      "type": "string",
      "minLength": 1
    },
    "evidence_label": {
      "type": "string",
      "enum": [
        "descriptive_segment_lift",
        "preference_heterogeneity",
        "behavioral_lift",
        "causal_hte",
        "uplift_targeting_label"
      ]
    },
    "calibration_level": {
      "type": "string",
      "enum": [
        "uncalibrated",
        "directionally_calibrated",
        "behaviorally_calibrated",
        "experimentally_validated"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_use": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_type": {
            "enum": ["synthetic_panel", "llm_interview", "expert_or_team_assumption"]
          }
        },
        "required": ["source_type"]
      },
      "then": {
        "not": {
          "properties": {
            "evidence_label": {
              "enum": ["causal_hte", "uplift_targeting_label"]
            }
          },
          "required": ["evidence_label"]
        }
      }
    }
  ]
}
